# ── App ──────────────────────────────────────────────
APP_PORT=3000

# ── PostgreSQL ───────────────────────────────────────
POSTGRES_DB=pdf_to_md
POSTGRES_PASSWORD=change-me-in-production

# ── MinIO (object storage, runs inside Docker) ──────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-in-production
MINIO_BUCKET=ocr-workspace
MINIO_CONSOLE_PORT=9001

# ── External Services (configure in web UI after startup) ──
# MinerU OCR server and VLM server are added via the
# "引擎配置" page at http://localhost:3000/engines
# Examples:
#   MinerU:  http://192.168.1.100:8888
#   VLM:     http://192.168.1.100:8000/v1
